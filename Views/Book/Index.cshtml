@model IEnumerable<Library.Web.Models.Book>
@{
    ViewData["Title"] = "Мои книги";
}

<h1>Мои книги</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить книгу</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Название</th>
            <th>Автор</th>
            <th>Жанр</th>
            <th>Год</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author?.FullName</td>
                <td>@book.Genre?.Name</td>
                <td>@book.PublicationYear</td>
                <td>
                    <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-info">Детали</a>
                    <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-warning">Редактировать</a>
                    <form asp-action="Delete" asp-route-id="@book.Id" method="post" style="display:inline">
                        <button type="submit" class="btn btn-danger">Удалить</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>